# auth0-mock environment template. Every var maps 1:1 to a field in
# internal/config/config.go; the README env-var table has the authoritative
# defaults and full prose. Copy this file to .env and adjust as needed.

# ── Listeners ──────────────────────────────────────────────────────────────
# Binary defaults to 127.0.0.1 for safety on bare-metal runs; the compose
# stack overrides to 0.0.0.0 so port-publishing works. Set to `off` to
# disable a listener entirely (empty-string can't disable because of how
# envconfig resolves defaults).
HTTP_ADDR=0.0.0.0:8080
HTTPS_ADDR=0.0.0.0:8443

# ── TLS (HTTPS listener only) ──────────────────────────────────────────────
# Persist auto-generated cert across restarts (recommended for compose):
# TLS_CACHE_DIR=/data/tls
# SAN entries on the auto-generated cert (CSV):
# TLS_HOSTNAMES=localhost,127.0.0.1,::1
# Or supply your own (e.g. via `mkcert`):
# TLS_CERT_FILE=/certs/tls.crt
# TLS_KEY_FILE=/certs/tls.key

# ── Signing key (RS256) ────────────────────────────────────────────────────
# Reuse a PEM-encoded RSA key across restarts so previously-minted tokens
# stay verifiable. If unset, a fresh key is generated on every boot —
# which means tokens minted by the /docs UI become invalid the moment
# `make watch` hot-reloads. Strongly recommended to set this in dev.
# /tmp is fine for dev (cleared on reboot, nothing sensitive in it);
# /data/signing.key is the conventional path inside the compose stack.
# SIGNING_KEY_FILE=/tmp/auth0-mock-dev-signing.key

# ── Token claims ───────────────────────────────────────────────────────────
ISSUER_URL=https://localhost:8443/
DEFAULT_AUDIENCE=https://localhost:8443/api/v2/
ACCESS_TOKEN_TTL=24h
ID_TOKEN_TTL=24h

# ── Logging ────────────────────────────────────────────────────────────────
# zerolog level: trace, debug, info, warn, error, fatal, panic. Invalid
# values warn on stderr and fall back to info.
LOG_LEVEL=info

# Dump every request + response (method, path, query, headers with bearer
# redacted, body capped at 8 KiB) at INFO level. The compiled binary
# defaults to `false`; this template flips it on so a fresh `cp .env.example .env`
# gives you the full SDK trace out of the box. Set to false (or comment
# out) if your terminal is getting too noisy. Local-dev only — costs an
# allocation and a synchronous log write per request.
DEBUG=true

# ── Spec validation ────────────────────────────────────────────────────────
# When true, response-side OpenAPI re-validation (defence in depth) is a
# hard error; when false, it logs but doesn't fail. Leave true in CI.
SPEC_VALIDATION_STRICT=true

# ── HTTP server timeouts ───────────────────────────────────────────────────
# Per-listener http.Server timeouts. WriteTimeout and IdleTimeout default
# to 0 (effectively unbounded) in the Go stdlib; the mock sets explicit
# values to defang slow-read / slow-write attacks.
# READ_HEADER_TIMEOUT=5s
# WRITE_TIMEOUT=30s
# IDLE_TIMEOUT=120s
# Graceful-shutdown grace period: how long to wait for in-flight requests
# to drain on SIGTERM / SIGINT before forcibly closing connections.
# SHUTDOWN_TIMEOUT=5s

# ── Body cap ───────────────────────────────────────────────────────────────
# Per-request body cap (bytes). Anything larger is rejected with 400 before
# reaching the handler. Default is 1 MiB. Set to 0 to disable.
# MAX_REQUEST_BODY_BYTES=1048576

# ── Logout / OIDC posture ──────────────────────────────────────────────────
# Comma-separated allow-list of absolute returnTo URLs that /v2/logout will
# 302 to. Empty (default) = no enforcement (SDK tests work out of the box).
# When set, mirrors Auth0's "Allowed Logout URLs": relative URLs always
# pass, unlisted absolutes get 400, dangerous schemes are rejected.
# LOGOUT_ALLOWED_URLS=https://app.example.com/post-logout,https://staging.example.com/post-logout

# Comma-separated allow-list of absolute redirect_uri values that
# /authorize will 302 to. Relative URIs are always allowed; unlisted
# absolute URIs get 400. Empty (default) = no enforcement (test SDKs can
# register any callback). Closes the open-redirect vector on /authorize.
# AUTHORIZE_ALLOWED_CALLBACKS=https://app.example.com/callback,https://localhost:3000/callback

# When set, the Mgmt-API bearer middleware rejects tokens whose `aud` claim
# doesn't contain this value (mirrors Auth0's tenant-API-audience binding).
# Empty preserves the "echoed, not enforced" default so tests can freely
# swap audiences.
# BEARER_REQUIRE_AUDIENCE=https://localhost:8443/api/v2/
