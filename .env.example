ENVIRONMENT=development
# Binary defaults to 127.0.0.1 for safety on bare-metal runs; the compose
# stack overrides to 0.0.0.0 so port-publishing works.
HTTP_ADDR=0.0.0.0:8080
HTTPS_ADDR=0.0.0.0:8443
# Persist auto-generated TLS cert across restarts (recommended for compose):
# TLS_CACHE_DIR=/data/tls
# Or supply your own (e.g. via `mkcert`):
# TLS_CERT_FILE=/certs/tls.crt
# TLS_KEY_FILE=/certs/tls.key
ISSUER_URL=https://localhost:8443/
DEFAULT_AUDIENCE=https://localhost:8443/api/v2/
ACCESS_TOKEN_TTL=24h
ID_TOKEN_TTL=24h
LOG_LEVEL=info
SPEC_VALIDATION_STRICT=true
# Per-listener http.Server timeouts. WriteTimeout and IdleTimeout default to 0
# (effectively unbounded) in the Go stdlib; the mock sets explicit values to
# defang slow-read / slow-write attacks.
# READ_HEADER_TIMEOUT=5s
# WRITE_TIMEOUT=30s
# IDLE_TIMEOUT=120s
# Per-request body cap (bytes). Anything larger is rejected with 413 before
# reaching the handler. Default is 1 MiB.
# MAX_REQUEST_BODY_BYTES=1048576
