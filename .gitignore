# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Local env
.env

# Build artifacts
/dist/
/bin/

# IDE
.idea/
.vscode/

# Coverage
coverage.out
/coverage/

# air (live-reload) scratch
/tmp/
build-errors.log

# Local-only Claude Code permission allowlist (workstation-specific).
.claude/

# Local-only design + implementation-plan working docs.
/docs/design/

# Raw, manually-downloaded Auth0 Management API spec. Only the stripped
# skeleton (api/auth0-management-api.openapi.json) is committed — see
# `make refresh-spec` and CONTRIBUTING.md.
/api/*.raw.json
/docs/plans/
